# Copy this file to `.env.local` and uncomment one provider block.
# Load precedence is:
# 1. existing shell environment
# 2. `.env.local`
# 3. `.env`

CLAW_TOOL_MODE=auto

# Generic or self-hosted OpenAI-compatible endpoint
# CLAW_PROVIDER=generic
# CLAW_BASE_URL=https://example.com/v1
# CLAW_MODEL=gpt-4.1-mini
# Optional when the endpoint requires auth
# CLAW_API_KEY=
# Optional when the endpoint expects a non-standard auth header
# CLAW_API_KEY_HEADER=authorization

# GLM
# CLAW_PROVIDER=glm
# GLM_API_KEY=
# GLM_MODEL=GLM-4.7
# Optional override
# GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# Kimi
# CLAW_PROVIDER=kimi
# KIMI_API_KEY=
# KIMI_MODEL=kimi-k2.5
# Optional override
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# Split reasoning + vision backbone
# Use the primary provider for reasoning, then let a second provider or model
# derive text-only visual context when a prompt includes `--image PATH`.
# Example: GLM-5.1 reasoning with Kimi K2.5 vision.
# CLAW_PROVIDER=glm
# GLM_API_KEY=
# GLM_MODEL=GLM-5.1
# CLAW_VISION_PROVIDER=kimi
# KIMI_API_KEY=
# CLAW_VISION_MODEL=kimi-k2.5
# Optional explicit overrides for the vision lane
# CLAW_VISION_BASE_URL=
# CLAW_VISION_API_KEY=
# CLAW_VISION_API_KEY_HEADER=authorization

# NVIDIA NIM
# CLAW_PROVIDER=nim
# NIM_API_KEY=
# NIM_MODEL=meta/llama-3.1-8b-instruct
# Optional override
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
